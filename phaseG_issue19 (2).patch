+            $sqlstatus = 'failed: user and database are required';
+        } else {
+            // Upsert: update existing link, else insert.
+            $sel = $conn->prepare(
+                "SELECT link_number FROM userdbaccess WHERE user_idno = ? AND db_name = ? LIMIT 1"
+            );
+            $sel->bind_param('is', $uid, $db);
